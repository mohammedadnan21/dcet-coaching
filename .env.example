# Direct connection for Prisma migrations (non-pooler)
DIRECT_URL="postgresql://user:password@hostname.region.aws.neon.tech/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-here"
