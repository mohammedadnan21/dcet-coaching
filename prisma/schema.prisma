generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Answer {
  id         String   @id @default(cuid())
  content    String
  questionId String
  answeredBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  answerer   User     @relation(fields: [answeredBy], references: [id])
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  content   String
  isBot     Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model DcetCutoff {
  id          String   @id @default(cuid())
  year        Int
  collegeName String
  collegeCode String
  branch      String
  branchCode  String
  category    String
  openingRank Int
  closingRank Int
  collegeType String
  location    String
  createdAt   DateTime @default(now())

  @@index([year, branch, category])
  @@index([year, closingRank])
}

model DeviceSession {
  id        String   @id @default(cuid())
  userId    String
  deviceId  String
  token     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

model MCQuestion {
  id            String       @id @default(cuid())
  testId        String
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String
  marks         Int          @default(1)
  createdAt     DateTime     @default(now())
  test          MockTest     @relation(fields: [testId], references: [id], onDelete: Cascade)
  testAnswers   TestAnswer[]

  @@index([testId])
}

model Meeting {
  id           String   @id @default(cuid())
  title        String
  description  String?
  zoomLink     String
  scheduledAt  DateTime
  hostId       String
  cancelled    Boolean  @default(false)
  cancelReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  host         User     @relation(fields: [hostId], references: [id])

  @@index([scheduledAt, cancelled])
}

model MockTest {
  id          String        @id @default(cuid())
  title       String
  description String?
  subjectId   String
  createdBy   String
  duration    Int
  showRanking Boolean       @default(false)
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  questions   MCQuestion[]
  creator     User          @relation(fields: [createdBy], references: [id])
  subject     Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  attempts    TestAttempt[]

  @@index([active, subjectId])
}

model MotivationQuote {
  id        String   @id @default(cuid())
  quote     String
  author    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active])
}

model OtpVerification {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model Question {
  id                            String   @id @default(cuid())
  content                       String
  askedById                     String
  targetId                      String?
  visibility                    String   @default("PUBLIC")
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  answers                       Answer[]
  askedBy                       User     @relation("Question_askedByIdToUser", fields: [askedById], references: [id], onDelete: Cascade)
  target                        User?    @relation("Question_targetIdToUser", fields: [targetId], references: [id])

  @@index([askedById])
  @@index([targetId])
  @@index([visibility])
}

model Subject {
  id             String           @id @default(cuid())
  name           String           @unique
  description    String?
  active         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  mockTests      MockTest[]
  teacherSubjects TeacherSubject[]
  videos         Video[]
}

model TeacherSubject {
  id        String   @id @default(cuid())
  teacherId String
  subjectId String
  createdAt DateTime @default(now())
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
}

model TestAnswer {
  id             String      @id @default(cuid())
  attemptId      String
  questionId     String
  selectedOption String?
  isCorrect      Boolean     @default(false)
  createdAt      DateTime    @default(now())
  attempt        TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       MCQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model TestAttempt {
  id          String       @id @default(cuid())
  testId      String
  userId      String
  score       Int          @default(0)
  totalMarks  Int          @default(0)
  completed   Boolean      @default(false)
  startedAt   DateTime     @default(now())
  completedAt DateTime?
  answers     TestAnswer[]
  test        MockTest     @relation(fields: [testId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([testId, userId])
  @@index([userId])
}

model User {
  id                                String           @id @default(cuid())
  name                              String
  email                             String           @unique
  phone                             String
  password                          String
  role                              String           @default("STUDENT")
  status                            String           @default("PENDING")
  isVerified                        Boolean          @default(false)
  createdAt                         DateTime         @default(now())
  updatedAt                         DateTime         @updatedAt
  answers                           Answer[]
  chatMessages                      ChatMessage[]
  deviceSessions                    DeviceSession[]
  meetings                          Meeting[]
  createdTests                      MockTest[]
  askedQuestions                    Question[]       @relation("Question_askedByIdToUser")
  targetedQuestions                 Question[]       @relation("Question_targetIdToUser")
  teacherSubjects                   TeacherSubject[]
  testAttempts                      TestAttempt[]
  videos                            Video[]

  @@index([role, status])
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  youtubeUrl  String
  subjectId   String
  uploadedBy  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  uploader    User     @relation(fields: [uploadedBy], references: [id])

  @@index([subjectId])
}
