generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Answer {
  id         String   @id
  content    String
  questionId String
  answeredBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  User       User     @relation(fields: [answeredBy], references: [id])
  Question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model ChatMessage {
  id        String   @id
  userId    String
  content   String
  isBot     Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model DcetCutoff {
  id          String   @id
  year        Int
  collegeName String
  collegeCode String
  branch      String
  branchCode  String
  category    String
  openingRank Int
  closingRank Int
  collegeType String
  location    String
  createdAt   DateTime @default(now())

  @@index([year, branch, category])
  @@index([year, closingRank])
}

model DeviceSession {
  id        String   @id
  userId    String
  deviceId  String
  token     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  expiresAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

model MCQuestion {
  id            String       @id
  testId        String
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String
  marks         Int          @default(1)
  createdAt     DateTime     @default(now())
  MockTest      MockTest     @relation(fields: [testId], references: [id], onDelete: Cascade)
  TestAnswer    TestAnswer[]

  @@index([testId])
}

model Meeting {
  id           String   @id
  title        String
  description  String?
  zoomLink     String
  scheduledAt  DateTime
  hostId       String
  cancelled    Boolean  @default(false)
  cancelReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  User         User     @relation(fields: [hostId], references: [id])

  @@index([scheduledAt, cancelled])
}

model MockTest {
  id          String        @id
  title       String
  description String?
  subjectId   String
  createdBy   String
  duration    Int
  showRanking Boolean       @default(false)
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  MCQuestion  MCQuestion[]
  User        User          @relation(fields: [createdBy], references: [id])
  Subject     Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  TestAttempt TestAttempt[]

  @@index([active, subjectId])
}

model MotivationQuote {
  id        String   @id
  quote     String
  author    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active])
}

model OtpVerification {
  id        String   @id
  email     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model Question {
  id                            String   @id
  content                       String
  askedById                     String
  targetId                      String?
  visibility                    String   @default("PUBLIC")
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime
  Answer                        Answer[]
  User_Question_askedByIdToUser User     @relation("Question_askedByIdToUser", fields: [askedById], references: [id], onDelete: Cascade)
  User_Question_targetIdToUser  User?    @relation("Question_targetIdToUser", fields: [targetId], references: [id])

  @@index([askedById])
  @@index([targetId])
  @@index([visibility])
}

model Subject {
  id             String           @id
  name           String           @unique
  description    String?
  active         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  MockTest       MockTest[]
  TeacherSubject TeacherSubject[]
  Video          Video[]
}

model TeacherSubject {
  id        String   @id
  teacherId String
  subjectId String
  createdAt DateTime @default(now())
  Subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
}

model TestAnswer {
  id             String      @id
  attemptId      String
  questionId     String
  selectedOption String?
  isCorrect      Boolean     @default(false)
  createdAt      DateTime    @default(now())
  TestAttempt    TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  MCQuestion     MCQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model TestAttempt {
  id          String       @id
  testId      String
  userId      String
  score       Int          @default(0)
  totalMarks  Int          @default(0)
  completed   Boolean      @default(false)
  startedAt   DateTime     @default(now())
  completedAt DateTime?
  TestAnswer  TestAnswer[]
  MockTest    MockTest     @relation(fields: [testId], references: [id], onDelete: Cascade)
  User        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([testId, userId])
  @@index([userId])
}

model User {
  id                                String           @id
  name                              String
  email                             String           @unique
  phone                             String
  password                          String
  role                              String           @default("STUDENT")
  status                            String           @default("PENDING")
  isVerified                        Boolean          @default(false)
  createdAt                         DateTime         @default(now())
  updatedAt                         DateTime
  Answer                            Answer[]
  ChatMessage                       ChatMessage[]
  DeviceSession                     DeviceSession[]
  Meeting                           Meeting[]
  MockTest                          MockTest[]
  Question_Question_askedByIdToUser Question[]       @relation("Question_askedByIdToUser")
  Question_Question_targetIdToUser  Question[]       @relation("Question_targetIdToUser")
  TeacherSubject                    TeacherSubject[]
  TestAttempt                       TestAttempt[]
  Video                             Video[]

  @@index([role, status])
}

model Video {
  id          String   @id
  title       String
  description String?
  youtubeUrl  String
  subjectId   String
  uploadedBy  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  User        User     @relation(fields: [uploadedBy], references: [id])

  @@index([subjectId])
}
